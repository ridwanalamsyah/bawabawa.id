{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && npm ci --include=dev",
  "buildCommand": "cd ../.. && npm run build --workspace @erp/site",
  "outputDirectory": ".next",
  "github": {
    "silent": true
  },
  "env": {
    "NEXT_TELEMETRY_DISABLED": "1"
  }
}
