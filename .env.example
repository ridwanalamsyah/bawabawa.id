# =============================================================================
# bawabawa.id — environment variables (production-ready template)
#
# Copy to `.env` for local docker-compose, or pipe into `fly secrets set …`
# for Fly.io. Never commit a populated `.env` to git.
# =============================================================================

# ── Runtime mode ────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Public canonical origin used for sitemap.xml + robots.txt + CORS hint.
PUBLIC_SITE_URL=https://bawabawa.id

# Comma-separated list of origins allowed by CORS. Empty = allow all (dev only).
CORS_ALLOWED_ORIGINS=https://bawabawa.id

# ── Database (Postgres) ─────────────────────────────────────────────────────
# Required in production. Format: postgres://user:password@host:5432/dbname
DATABASE_URL=postgres://erp:erp@db:5432/erp_db

# ── JWT signing secrets ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace-me-with-32-bytes-of-entropy-or-more
JWT_REFRESH_SECRET=replace-me-with-different-32-bytes-of-entropy

# ── Google Sign-In (Identity Services / ID-token flow) ──────────────────────
# Required in production. Create at:
#   https://console.cloud.google.com/apis/credentials
#   → Create Credentials → OAuth client ID → Web application
#
# Authorized JavaScript origins must include your PUBLIC_SITE_URL.
# Client Secret is NOT required (we use ID-token flow, not auth-code).
GOOGLE_OAUTH_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# Optional: comma-separated list of email domains auto-approved on first
# sign-in. Anyone outside the list still authenticates but lands on
# status='pending' awaiting an admin approval.
# Example: only allow @bawabawa.id and @bawabawa.co.id employees.
OAUTH_ALLOWED_DOMAINS=bawabawa.id

# Set to "false" to skip the manual-approval step (NOT recommended for
# public-facing deployments). Default is "true".
OAUTH_REQUIRE_APPROVAL=true

# ── Demo mode ───────────────────────────────────────────────────────────────
# Must be unset or false in production. Enables the legacy email/password form
# (admin@erp.com / admin123) for local development only.
# DEMO_MODE=false
